# frozen_string_literal: true

require 'rspec/core/rake_task'

RSpec::Core::RakeTask.new(:spec)

task default: :spec

# Load tasks from lib/tasks/*.rake (operator plumbing — fixtures rebuild
# lives there to keep the orchestration class unit-testable, with the
# rake file as a thin wrapper).
Dir.glob(File.expand_path('lib/tasks/*.rake', __dir__)).each { |t| load t }

namespace :brc29 do
  desc 'Refuse inline BRC-29 key_id composition outside lib/bsv/wallet/brc29.rb. ' \
       'Run in CI to enforce that every send/receive site routes through BSV::Wallet::BRC29.key_id.'
  task :guard do
    pattern = 'key_id:[[:space:]]*"\#\{[^"]+\} \#\{'
    matches = `git grep -nE '#{pattern}' -- 'lib' ':!lib/bsv/wallet/brc29.rb'`
    if matches.strip.empty?
      puts 'brc29:guard OK (no inline key_id composition outside brc29.rb)'
    else
      warn 'brc29:guard FAILED -- inline key_id interpolation detected outside ' \
           'lib/bsv/wallet/brc29.rb. Route through BSV::Wallet::BRC29.key_id(prefix, suffix) ' \
           'instead. Offending lines:'
      warn matches
      abort
    end
  end
end

namespace :wallet do
  desc 'Drain a wallet back to its root key (consolidate + on-chain sweep). ' \
       'Usage: rake wallet:cleanup[alice] or rake wallet:cleanup[alice,<root_pubkey_hex>]'
  task :cleanup, %i[wallet recipient] do |_t, args|
    require_relative 'lib/bsv/wallet/cli'

    ctx = BSV::Wallet::CLI.boot(wallet_name: args[:wallet])
    result = ctx[:engine].sweep_to_root(recipient: args[:recipient])

    if result[:sweep].nil?
      warn 'cleanup: nothing to sweep — wallet has no spendable outputs'
    else
      dtxid = result[:sweep][:txid].reverse.unpack1('H*')
      warn "cleanup: #{result[:consolidation_steps]} consolidation step(s); swept to root, dtxid=#{dtxid}"
    end
  end
end

namespace :docs do # rubocop:disable Metrics/BlockLength
  desc 'Generate YARD markdown into docs/reference/api/'
  task :generate do
    require 'fileutils'
    project_root = File.expand_path('../..', __dir__)
    # YARD output lives in its own +api/+ sub-dir per the documentation
    # strategy. Authored content (schema, principle-of-state, etc.) sits
    # at +docs/reference/+ as siblings; isolating YARD's nuclear cleanup
    # to +api/+ keeps the authored docs out of the rm_rf line of fire.
    output_dir = File.join(project_root, 'docs/reference/api')
    FileUtils.rm_rf(output_dir)
    FileUtils.mkdir_p(output_dir)
    sh "bundle exec yardoc --plugin markdown --format markdown --output-dir #{output_dir} lib/**/*.rb"
    generate_reference_index(output_dir)
  end

  desc 'Build the Jekyll docs site'
  task :build do
    project_root = File.expand_path('../..', __dir__)
    Dir.chdir(File.join(project_root, 'docs')) do
      sh 'BUNDLE_GEMFILE=Gemfile bundle exec jekyll build'
    end
  end

  desc 'Serve the Jekyll docs locally with live reload'
  task :serve do
    project_root = File.expand_path('../..', __dir__)
    Dir.chdir(File.join(project_root, 'docs')) do
      sh 'BUNDLE_GEMFILE=Gemfile bundle exec jekyll serve --livereload'
    end
  end

  desc 'Lint docs frontmatter — asserts required keys on every hand-authored .md'
  task :lint do # rubocop:disable Metrics/BlockLength
    require 'yaml'

    project_root = File.expand_path('../..', __dir__)
    docs_root = File.join(project_root, 'docs')

    # Exclude generated and non-content paths:
    #   _site/        — Jekyll output, not source
    #   reference/api/ — YARD-generated, no hand-authored frontmatter
    #   vendor/       — CI bundler-cache lands gems here; their READMEs
    #                   are not our docs
    #   .bundle/      — Bundler config dir
    #   README.md     — contributor meta-documentation, not a site page
    excluded_prefixes = [
      File.join(docs_root, '_site'),
      File.join(docs_root, 'reference', 'api'),
      File.join(docs_root, 'vendor'),
      File.join(docs_root, '.bundle')
    ]
    excluded_files = [File.join(docs_root, 'README.md')]

    md_files = Dir.glob(File.join(docs_root, '**', '*.md')).reject do |f|
      # Add a trailing path separator to each prefix so the match is strict
      # directory containment (e.g. `docs/vendor/x.md` matches `docs/vendor`
      # but a hypothetical `docs/vendorized/x.md` would not).
      excluded_prefixes.any? { |prefix| f.start_with?("#{prefix}/") } ||
        excluded_files.include?(f)
    end

    errors = []

    md_files.each do |path|
      content = File.read(path)

      unless content.start_with?('---')
        errors << "#{path}: missing frontmatter block (file must begin with ---)"
        next
      end

      fm_match = content.match(/\A---\s*\n(.*?)\n---/m)
      unless fm_match
        errors << "#{path}: malformed frontmatter (no closing ---)"
        next
      end

      fm = YAML.safe_load(fm_match[1]) || {}

      unless fm['title']
        errors << "#{path}: missing required frontmatter key: title"
        next
      end

      # nav_order is required for every nav-bearing page. Without it,
      # just-the-docs falls back to alphabetical, which silently breaks the
      # MkDocs nav order this migration preserves. Stubs hidden from nav
      # (nav_exclude: true) and the root index are the only exemptions.
      is_root_index = path == File.join(docs_root, 'index.md')
      unless fm['nav_exclude'] || is_root_index || fm['nav_order']
        errors << "#{path}: missing required frontmatter key: nav_order"
        next
      end

      next if is_root_index
      next if fm['has_children']
      next if fm['parent'] || fm['nav_exclude']

      # Top-level pages (directly under docs/, no subdirectory) are
      # intentionally section-less peers of the section landings — they
      # appear at the top level of the nav alongside Home. Allow them
      # without a parent.
      next if File.dirname(path) == docs_root

      errors << "#{path}: missing 'parent' or 'nav_exclude' — " \
                'non-root, non-section pages must declare one or the other'
    end

    if errors.empty?
      puts "docs:lint — #{md_files.size} file(s) checked, all OK"
    else
      errors.each { |e| warn e }
      exit 1
    end
  end

  desc 'Check internal links and anchors in the built site (offline)'
  task :proofread do
    # No Rake-level dependency on :build so CI can run them as separate
    # steps without rebuilding twice. Callers (CI + local) are expected
    # to have run `rake docs:build` first; surface a clear message
    # rather than letting htmlproofer fail with an opaque "no files".
    project_root = File.expand_path('../..', __dir__)
    site_dir = File.join(project_root, 'docs/_site')
    unless File.directory?(site_dir) && !Dir.empty?(site_dir)
      abort "docs:proofread — #{site_dir} is missing or empty. " \
            'Run `bundle exec rake docs:build` first.'
    end

    Dir.chdir(File.join(project_root, 'docs')) do
      # html-proofer is Jekyll-aware: swap_urls strips the baseurl prefix
      # (which is a URL concept, not a filesystem path) so root-relative
      # links like /bsv-wallet/concepts/architecture/ resolve to
      # _site/concepts/architecture/. disable_external skips https://
      # links — those need network.
      #
      # Carve-outs (mirrors the carve-out gate the MkDocs workflow had):
      #
      # 1. Out-of-repo ../.architecture/ references are intentional
      #    cross-links to ADRs/reviews that don't ship with the docs site.
      #    They resolve on GitHub but htmlproofer cannot find them locally.
      #
      # 2. reference/external/ — vendored upstream specs (e.g. BRC-100)
      #    contain sibling-BRC links (../wallet/0100.md, ../key-derivation/
      #    0042.md, etc.) that we deliberately don't ship.
      #
      # 3. reference/drafts/ — drafts use the same cross-BRC link
      #    convention; same rationale.
      sh 'BUNDLE_GEMFILE=Gemfile bundle exec htmlproofer _site ' \
         '--disable-external ' \
         '--swap-urls "^/bsv-wallet:" ' \
         '--ignore-urls "/\\.architecture\\//" ' \
         '--ignore-files "/_site/reference/(external|drafts)/" ' \
         '--ignore-empty-alt ' \
         '--ignore-missing-alt ' \
         '--allow-missing-href'
    end
  end
end

def generate_reference_index(output_dir)
  require 'csv'
  csv_path = File.join(output_dir, 'index.csv')
  return unless File.exist?(csv_path)

  modules = []
  classes = []
  CSV.foreach(csv_path, headers: true) do |row|
    next unless %w[Module Class].include?(row['type'])

    entry = { name: row['name'], path: row['path'] }
    row['type'] == 'Module' ? modules << entry : classes << entry
  end

  File.open(File.join(output_dir, 'index.md'), 'w') do |f|
    # Jekyll frontmatter — Jekyll only processes .md files with frontmatter
    # as content pages; without it, this file is copied verbatim as .md and
    # _site/reference/api/index.html never exists. The defaults block in
    # _config.yml additionally keeps it out of the side nav and search index.
    f.puts '---'
    f.puts 'title: API Reference'
    f.puts 'parent: Reference'
    f.puts 'nav_order: 99'
    f.puts '---'
    f.puts
    f.puts '# API Reference'
    f.puts
    f.puts 'Auto-generated from source using [YARD](https://yardoc.org/).'
    f.puts
    f.puts '## Modules'
    f.puts
    modules.sort_by { |e| e[:name] }.each { |e| f.puts "- [#{e[:name]}](#{e[:path]})" }
    f.puts
    f.puts '## Classes'
    f.puts
    classes.sort_by { |e| e[:name] }.each { |e| f.puts "- [#{e[:name]}](#{e[:path]})" }
  end
end
