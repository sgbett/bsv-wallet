# frozen_string_literal: true

require 'rspec/core/rake_task'

RSpec::Core::RakeTask.new(:spec)

task default: :spec

# Load tasks from lib/tasks/*.rake (operator plumbing — fixtures rebuild
# lives there to keep the orchestration class unit-testable, with the
# rake file as a thin wrapper).
Dir.glob(File.expand_path('lib/tasks/*.rake', __dir__)).each { |t| load t }

namespace :brc29 do
  desc 'Refuse inline BRC-29 key_id composition outside lib/bsv/wallet/brc29.rb. ' \
       'Run in CI to enforce that every send/receive site routes through BSV::Wallet::BRC29.key_id.'
  task :guard do
    pattern = 'key_id:\s*"\#\{[^"]+\} \#\{'
    matches = `git grep -nE '#{pattern}' -- 'lib' ':!lib/bsv/wallet/brc29.rb'`
    if matches.strip.empty?
      puts 'brc29:guard OK (no inline key_id composition outside brc29.rb)'
    else
      warn 'brc29:guard FAILED -- inline key_id interpolation detected outside ' \
           'lib/bsv/wallet/brc29.rb. Route through BSV::Wallet::BRC29.key_id(prefix, suffix) ' \
           'instead. Offending lines:'
      warn matches
      abort
    end
  end
end

namespace :wallet do
  desc 'Drain a wallet back to its root key (consolidate + on-chain sweep). ' \
       'Usage: rake wallet:cleanup[alice] or rake wallet:cleanup[alice,<root_pubkey_hex>]'
  task :cleanup, %i[wallet recipient] do |_t, args|
    require_relative 'lib/bsv/wallet/cli'

    ctx = BSV::Wallet::CLI.boot(wallet_name: args[:wallet])
    result = ctx[:engine].sweep_to_root(recipient: args[:recipient])

    if result[:sweep].nil?
      warn 'cleanup: nothing to sweep — wallet has no spendable outputs'
    else
      dtxid = result[:sweep][:txid].reverse.unpack1('H*')
      warn "cleanup: #{result[:consolidation_steps]} consolidation step(s); swept to root, dtxid=#{dtxid}"
    end
  end
end

namespace :docs do
  desc 'Generate YARD markdown into docs/reference/api/'
  task :generate do
    require 'fileutils'
    project_root = File.expand_path('../..', __dir__)
    # YARD output lives in its own +api/+ sub-dir per the documentation
    # strategy. Authored content (schema, principle-of-state, etc.) sits
    # at +docs/reference/+ as siblings; isolating YARD's nuclear cleanup
    # to +api/+ keeps the authored docs out of the rm_rf line of fire.
    output_dir = File.join(project_root, 'docs/reference/api')
    FileUtils.rm_rf(output_dir)
    FileUtils.mkdir_p(output_dir)
    sh "bundle exec yardoc --plugin markdown --format markdown --output-dir #{output_dir} lib/**/*.rb"
    generate_reference_index(output_dir)
  end

  desc 'Generate docs and serve locally with MkDocs'
  task serve: :generate do
    project_root = File.expand_path('../..', __dir__)
    Dir.chdir(project_root) { sh 'mkdocs serve' }
  end
end

def generate_reference_index(output_dir)
  require 'csv'
  csv_path = File.join(output_dir, 'index.csv')
  return unless File.exist?(csv_path)

  modules = []
  classes = []
  CSV.foreach(csv_path, headers: true) do |row|
    next unless %w[Module Class].include?(row['type'])

    entry = { name: row['name'], path: row['path'] }
    row['type'] == 'Module' ? modules << entry : classes << entry
  end

  File.open(File.join(output_dir, 'index.md'), 'w') do |f|
    f.puts '# API Reference'
    f.puts
    f.puts 'Auto-generated from source using [YARD](https://yardoc.org/).'
    f.puts
    f.puts '## Modules'
    f.puts
    modules.sort_by { |e| e[:name] }.each { |e| f.puts "- [#{e[:name]}](#{e[:path]})" }
    f.puts
    f.puts '## Classes'
    f.puts
    classes.sort_by { |e| e[:name] }.each { |e| f.puts "- [#{e[:name]}](#{e[:path]})" }
  end
end
