# CLI tools and integration test environment variables.
# Copy to .env and fill in values.
#
# Wallet specifier convention:
#   bin/send alice ...  → reads WIF_ALICE, DATABASE_URL_ALICE
#   bin/send bob ...    → reads WIF_BOB, DATABASE_URL_BOB
#   bin/send ...        → reads WIF, DATABASE_URL (default)

# Wallet keys (WIF format, mainnet)
WIF_ALICE=
WIF_BOB=

# Separate databases for each wallet (same server, different databases)
DATABASE_URL_ALICE=postgres://postgres:postgres@localhost:5433/bsv_wallet_alice
DATABASE_URL_BOB=postgres://postgres:postgres@localhost:5433/bsv_wallet_bob

# Funding transaction (send to Alice's root key address, then fill in)
FUNDING_TXID=
FUNDING_VOUT=0
FUNDING_SATOSHIS=2000
