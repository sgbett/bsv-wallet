#!/usr/bin/env ruby
# frozen_string_literal: true

# Reject a broadcast action whose network outcome was terminal-REJECTED.
#
# Cascades forward through any descendant action that consumed this
# action's outputs (recursive, single outer transaction). Refuses on:
#
#   - +broadcast_intent='none'+ target or cascade descendant.
#     Internal-path actions produce canonical wallet state by design;
#     rejecting them would destroy that state. Raises
#     +CannotRejectInternalActionError+ and the cascade rolls back.
#
#   - +tx_status+ in +ACCEPTED_STATUSES+ on the target or any cascade
#     descendant (SEEN_ON_NETWORK / ACCEPTED_BY_NETWORK / MINED /
#     IMMUTABLE). The network told us this tx is on chain — deletion
#     compounds the wallet-vs-chain divergence rather than recovering
#     from it. Raises +CannotRejectAcceptedActionError+ and rolls back.
#
# The daemon's resolution loop calls Store#reject_action directly when
# polling finds a terminal-REJECTED status. This wrapper is for
# operator-driven cleanup of rows the daemon can't recover (e.g.,
# pre-daemon stuck rows; rows whose resolution-loop polling missed the
# REJECTED transition).
#
# Usage:
#   bin/reject [wallet] --action-id <id>
#
# Prints JSON result to stdout; human-readable detail to stderr.

require_relative '../lib/bsv/wallet/cli'
require 'optparse'
require 'json'

wallet_name, args = BSV::Wallet::CLI.extract_wallet_name(ARGV)

options = {}
OptionParser.new do |opts|
  opts.banner = 'Usage: bin/reject [wallet] --action-id <id>'
  opts.on('--action-id N', Integer, 'Local action_id to reject') { |v| options[:action_id] = v }
end.parse!(args)

abort 'Missing --action-id <id>' unless options[:action_id]

ctx = BSV::Wallet::CLI.boot(wallet_name: wallet_name)
engine = ctx[:engine]

begin
  result = engine.reject_action(action_id: options[:action_id])
  $stdout.puts JSON.generate(result)
  warn "rejected action_id=#{options[:action_id]} (cascade complete)"
rescue BSV::Wallet::CannotRejectInternalActionError,
       BSV::Wallet::CannotRejectAcceptedActionError => e
  warn "reject refused: #{e.message}"
  $stdout.puts JSON.generate({ rejected: false, reason: e.class.name, message: e.message })
  exit 1
rescue BSV::Wallet::InvalidParameterError => e
  warn "invalid: #{e.message}"
  exit 2
end
