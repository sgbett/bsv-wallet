#!/usr/bin/env ruby
# frozen_string_literal: true

# Import root-key UTXOs from the network (porcelain).
#
# Scans the wallet's root key address for unspent outputs and imports
# each one via engine.import_utxo (self-payment to a BRC-42 derived address).
#
# Usage:
#   bin/import <wallet>
#
# Prints imported count to stdout (machine-readable).
# Prints detail to stderr (human-readable).

require_relative '../lib/bsv/wallet/cli'

wallet_name = ARGV.shift

abort 'Usage: bin/import <wallet>' unless wallet_name

ctx = BSV::Wallet::CLI.boot(wallet_name: wallet_name)

result = ctx[:engine].import_wallet

$stdout.puts result[:imported]
result[:utxos].each do |utxo|
  warn "  #{utxo[:satoshis]} sats (#{utxo[:dtxid]})"
end
warn "Imported #{result[:imported]} UTXOs"
