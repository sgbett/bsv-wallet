#!/usr/bin/env ruby
# frozen_string_literal: true

# Import a root-key UTXO by txid and output index (porcelain).
#
# Thin wrapper over engine.import_utxo — fetches the transaction from
# the network, verifies the output is P2PKH to the wallet's root key,
# and immediately pays to a BRC-42 derived self-address.
#
# Usage:
#   bin/import <wallet> <dtxid> <vout>
#
# Prints satoshis to stdout (machine-readable).
# Prints detail to stderr (human-readable).

require_relative '../lib/bsv/wallet/cli'

wallet_name = ARGV.shift
dtxid = ARGV.shift
vout = ARGV.shift

abort 'Usage: bin/import <wallet> <dtxid> <vout>' unless wallet_name && dtxid&.match?(/\A[0-9a-f]{64}\z/i) && vout&.match?(/\A\d+\z/)

ctx = BSV::Wallet::CLI.boot(wallet_name: wallet_name)

result = ctx[:engine].import_utxo(dtxid: dtxid, vout: vout.to_i)

$stdout.puts result[:satoshis]
warn "Imported #{result[:satoshis]} sats (#{result[:dtxid]})"
