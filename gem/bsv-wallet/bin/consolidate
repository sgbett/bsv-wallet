#!/usr/bin/env ruby
# frozen_string_literal: true

# Consolidate dustier UTXOs into a single self-payment.
#
# Loops Engine#consolidate_step until the wallet has fewer than
# +target_inputs+ spendable outputs. Each step consumes the
# +target_inputs+ smallest spendable outputs plus the largest as an
# anchor, producing one BRC-42 self-derived output.
#
# Usage:
#   bin/consolidate [wallet] [--target-inputs N] [--no-send]
#
# Broadcast mode mirrors bin/create / bin/import / bin/sweep:
#   (default)  — engine defaults (no_send: false, accept_delayed_broadcast:
#                true). Each step is queued for walletd; outputs promote on
#                broadcast. Used by the e2e harness's on-chain consolidation
#                before the broadcast workload.
#   --no-send  — each step is built without broadcasting; outputs promote
#                locally. Used by integration tests that exchange BEEF
#                peer-to-peer without touching the network.
#
# Prints summary to stderr; final spendable count to stdout.

require_relative '../lib/bsv/wallet/cli'
require 'optparse'

wallet_name, args = BSV::Wallet::CLI.extract_wallet_name(ARGV)

options = { target_inputs: 20 }
OptionParser.new do |opts|
  opts.banner = 'Usage: bin/consolidate [wallet] [--target-inputs N] [--no-send]'
  opts.on('--target-inputs N', Integer, 'Inputs consumed per step (default: 20)') { |v| options[:target_inputs] = v }
  opts.on('--no-send', 'Build steps without broadcasting (promote locally)') { options[:no_send] = true }
end.parse!(args)

ctx = BSV::Wallet::CLI.boot(wallet_name: wallet_name)
engine = ctx[:engine]

steps = 0
loop do
  result = engine.consolidate_step(target_inputs: options[:target_inputs],
                                   no_send: options[:no_send] || false)
  break if result.nil?

  steps += 1
  warn "consolidation step #{steps}: dtxid=#{result[:txid].reverse.unpack1('H*')}"
end

# Pool snapshot after consolidation.
balance = ctx[:utxo_pool].balance
count = ctx[:utxo_pool].spendable_count

$stdout.puts count
warn "consolidated #{steps} step(s); #{count} spendable output(s), #{balance} sats"
