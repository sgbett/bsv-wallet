#!/usr/bin/env ruby
# frozen_string_literal: true

# Sweep every spendable output back to a root key (less fee).
#
# Builds one transaction consuming all spendable UTXOs and emitting a
# single P2PKH output to the recipient's *root* address
# (+hash160(recipient_pubkey)+, not a BRC-42-derived one). The literal
# root P2PKH is recoverable from the WIF alone, which is the whole point
# of a sweep — return the funds somewhere a bare key can reclaim them.
# Used by the #130 consolidation dry-run and the #126 on-chain
# sweep-back to the SDK identity.
#
# Usage:
#   bin/sweep [wallet] --to <identity_key_hex> [--no-send]
#
# Broadcast mode mirrors bin/create / bin/import / bin/consolidate:
#   (default)  — engine defaults (no_send: false, accept_delayed_broadcast:
#                true). Sweep is queued for walletd to push on chain.
#                Used by the #126 e2e on-chain return-to-SDK flow.
#   --no-send  — sweep built without broadcasting; the sweeping wallet
#                ends at zero spendable locally. BEEF can be handed off if
#                needed. Used by the #130 consolidation dry-run.
#
# Prints sweep summary to stderr; final balance to stdout.

require_relative '../lib/bsv/wallet/cli'
require 'optparse'

wallet_name, args = BSV::Wallet::CLI.extract_wallet_name(ARGV)

options = {}
OptionParser.new do |opts|
  opts.banner = 'Usage: bin/sweep [wallet] --to <identity_key_hex> [--no-send]'
  opts.on('--to KEY', 'Recipient compressed pubkey (66-char hex, 02/03 prefix)') { |v| options[:to] = v }
  opts.on('--no-send', 'Build sweep without broadcasting (local only)') { options[:no_send] = true }
end.parse!(args)

abort 'Missing --to <identity_key_hex>' unless options[:to]

ctx = BSV::Wallet::CLI.boot(wallet_name: wallet_name)
engine = ctx[:engine]

result = engine.sweep(recipient: options[:to], no_send: options[:no_send] || false)
if result.nil?
  warn 'nothing to sweep — wallet has no spendable outputs'
  $stdout.puts 0
  exit 0
end

balance = ctx[:utxo_pool].balance
$stdout.puts balance
warn "swept to #{options[:to][0..15]}...; dtxid=#{result[:txid].reverse.unpack1('H*')}, remaining balance=#{balance} sats"
