#!/usr/bin/env ruby
# frozen_string_literal: true

# Import a root-key P2PKH UTXO into the wallet.
#
# The engine fetches the transaction from the network, verifies the output
# is P2PKH to the wallet's root key, and immediately pays to a derived
# self-address. The root key UTXO never persists as spendable.
#
# Usage:
#   bin/import_root_utxo [wallet] <dtxid_hex> [vout] [--basket <name>]
#
# Basket semantics (HLR #436):
#   no --basket flag → imported funds land unbasketed (wallet's pool)
#   --basket <name>  → imported funds land in the named basket; queryable
#                      via +listOutputs(basket: <name>)+ and not consumed
#                      by auto-funding (HLR #435)

require_relative '../lib/bsv/wallet/cli'
require 'optparse'

wallet_name, args = BSV::Wallet::CLI.extract_wallet_name(ARGV)

options = {}
positional = OptionParser.new do |opts|
  opts.banner = 'Usage: bin/import_root_utxo [wallet] <dtxid_hex> [vout] [--basket <name>]'
  opts.on('--basket NAME', 'Route imported funds into the named basket (default: unbasketed)') do |v|
    options[:basket] = v
  end
end.parse(args)

dtxid = positional[0]
vout = (positional[1] || 0).to_i

abort 'Usage: bin/import_root_utxo [wallet] <dtxid_hex> [vout] [--basket <name>]' unless dtxid&.match?(/\A[0-9a-f]{64}\z/i)

ctx = BSV::Wallet::CLI.boot(wallet_name: wallet_name)

result = ctx[:engine].import_utxo(dtxid: dtxid, vout: vout, basket: options[:basket])

listed = ctx[:engine].spendable_outputs(basket: options[:basket])
warn "Imported #{result[:satoshis]} sats (#{result[:dtxid]})"
warn "Basket: #{options[:basket] || '(unbasketed)'}"
warn "Spendable outputs in basket: #{listed[:total]}"
warn "Total in basket: #{listed[:outputs].sum { |o| o[:satoshis] }} sats"
