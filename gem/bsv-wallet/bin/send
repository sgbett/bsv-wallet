#!/usr/bin/env ruby
# frozen_string_literal: true

# Send a P2PKH payment (porcelain).
#
# Composes UTXO selection, script construction, and create_action
# into a single command. Outputs BEEF to stdout for piping to
# bin/receive or bin/internalize.
#
# Usage:
#   bin/send [wallet] --to <identity_key_hex> --sats <amount> [--fee <rate>]
#
# Writes binary BEEF to stdout (pipe to bin/receive or bin/internalize).
# Writes transaction summary to stderr.

require_relative '../lib/bsv/wallet/cli'
require 'optparse'

wallet_name, args = BSV::Wallet::CLI.extract_wallet_name(ARGV)

options = {}
OptionParser.new do |opts|
  opts.banner = 'Usage: bin/send [wallet] --to <identity_key> --sats <amount> [--fee <rate>]'
  opts.on('--to KEY', 'Recipient identity key (66-char compressed hex)') { |v| options[:to] = v }
  opts.on('--sats N', Integer, 'Amount to send in satoshis') { |v| options[:sats] = v }
  opts.on('--fee N', Integer, 'Fee rate in sats/byte (default: 1)') { |v| options[:fee_rate] = v }
  opts.on('-b', 'Force binary output to TTY') { options[:binary] = true }
  opts.on('-o FILE', 'Write BEEF to file') { |v| options[:output_file] = v }
end.parse!(args)

unless options[:to]&.match?(/\A(?:02|03)[0-9a-fA-F]{64}\z/)
  abort 'Missing or invalid --to (expected 66-char compressed public key hex)'
end
abort 'Missing --sats' unless options[:sats]&.positive?

ctx = BSV::Wallet::CLI.boot(wallet_name: wallet_name)
engine = ctx[:engine]
payment = options[:sats]
fee_rate = options[:fee_rate] || 1

# UTXO selection
candidates = ctx[:utxo_pool].select(satoshis: payment)
input_sats = candidates.sum { |c| c[:satoshis] }

# Fee estimation: inputs * 148 + outputs * 34 + 10 (standard P2PKH sizes)
num_inputs = candidates.length
num_outputs = 2 # payment + change
estimated_size = num_inputs * 148 + num_outputs * 34 + 10
fee = estimated_size * fee_rate

change = input_sats - payment - fee
if change.negative?
  abort "Insufficient funds: have #{input_sats}, need #{payment + fee} (#{payment} + #{fee} fee)"
end

# Build locking scripts
recipient_hash = BSV::Primitives::Digest.hash160([options[:to]].pack('H*'))
recipient_script = BSV::Script::Script.p2pkh_lock(recipient_hash).to_binary

self_hash = BSV::Primitives::Digest.hash160([ctx[:identity_key]].pack('H*'))
self_script = BSV::Script::Script.p2pkh_lock(self_hash).to_binary

# Build inputs from selected UTXOs
inputs = candidates.each_with_index.map { |c, i| { output_id: c[:id], vin: i } }

# Build outputs — payment has no output_type (not ours), change is explicit
outputs = [
  { satoshis: payment, locking_script: recipient_script,
    output_description: 'payment' },
  { satoshis: change, locking_script: self_script,
    output_description: 'change', output_type: 'change' }
]

result = engine.create_action(
  description: "send #{payment} sats",
  inputs: inputs,
  outputs: outputs,
  labels: ['cli-send'],
  no_send: true,
  randomize_outputs: false
)

BSV::Wallet::CLI::Output.write_binary(result[:tx],
  output_file: options[:output_file],
  binary: options[:binary])

dtxid = result[:txid].reverse.unpack1('H*')
$stderr.puts "dtxid:  #{dtxid}"
$stderr.puts "sent:   #{payment} sats to #{options[:to][0..7]}..."
$stderr.puts "change: #{change} sats (#{num_inputs} input(s), #{estimated_size} bytes)"
$stderr.puts "fee:    #{fee} sats (#{fee_rate} sat/byte)"
