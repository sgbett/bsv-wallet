#!/usr/bin/env ruby
# frozen_string_literal: true

warn '[DEPRECATED] bin/send is deprecated — use bin/create instead'

# Send a BRC-100 payment with BRC-42 derived keys (plumbing).
#
# Generates derivation parameters for both the payment and change outputs,
# derives P2PKH locking scripts via BRC-42, calls create_action, and
# outputs a JSON envelope containing BEEF + derivation metadata for the
# recipient to internalize.
#
# Usage:
#   bin/send [wallet] --to <identity_key_hex> --sats <amount> [--fee <sats>]
#
# Stdout: JSON envelope { beef: <hex>, outputs: [...] }
# Stderr: human-readable summary

require_relative '../lib/bsv/wallet/cli'
require 'optparse'
require 'securerandom'
require 'json'

wallet_name, args = BSV::Wallet::CLI.extract_wallet_name(ARGV)

options = {}
OptionParser.new do |opts|
  opts.banner = 'Usage: bin/send [wallet] --to <identity_key> --sats <amount> [--fee <sats>]'
  opts.on('--to KEY', 'Recipient identity key (66-char compressed hex)') { |v| options[:to] = v }
  opts.on('--sats N', Integer, 'Amount to send in satoshis') { |v| options[:sats] = v }
  opts.on('--fee N', Integer, 'Fee in satoshis (default: 1)') { |v| options[:fee] = v }
end.parse!(args)

abort 'Missing or invalid --to (expected 66-char compressed public key hex)' unless options[:to]&.match?(/\A(?:02|03)[0-9a-fA-F]{64}\z/)
abort 'Missing --sats' unless options[:sats]&.positive?

ctx = BSV::Wallet::CLI.boot(wallet_name: wallet_name)
engine = ctx[:engine]
key_deriver = ctx[:key_deriver]
payment = options[:sats]
fee = options[:fee] || 1

# UTXO selection
candidates = ctx[:utxo_pool].select(satoshis: payment + fee)
input_sats = candidates.sum { |c| c[:satoshis] }

change = input_sats - payment - fee
abort "Insufficient funds: have #{input_sats}, need #{payment + fee}" if change.negative?

# Payment output: BRC-42 derived key for recipient
pay_prefix = SecureRandom.uuid
pay_suffix = '1'
pay_derived_pub = key_deriver.derive_public_key(
  protocol_id: [2, pay_prefix], key_id: pay_suffix,
  counterparty: options[:to], for_self: true
)
pay_script = BSV::Script::Script.p2pkh_lock(
  BSV::Primitives::Digest.hash160(pay_derived_pub)
).to_binary

# Change output: BRC-42 derived key for self
chg_prefix = SecureRandom.uuid
chg_suffix = '1'
chg_derived_pub = key_deriver.derive_public_key(
  protocol_id: [2, chg_prefix], key_id: chg_suffix,
  counterparty: 'self'
)
chg_script = BSV::Script::Script.p2pkh_lock(
  BSV::Primitives::Digest.hash160(chg_derived_pub)
).to_binary

# Build inputs/outputs
inputs = candidates.each_with_index.map { |c, i| { output_id: c[:id], vin: i } }
outputs = [
  { satoshis: payment, locking_script: pay_script },
  { satoshis: change, locking_script: chg_script,
    derivation_prefix: chg_prefix, derivation_suffix: chg_suffix,
    sender_identity_key: ctx[:identity_key] }
]

result = engine.create_action(
  description: "send #{payment} sats",
  inputs: inputs,
  outputs: outputs,
  labels: ['cli-send'],
  no_send: true,
  randomize_outputs: false
)

# Output JSON envelope with BEEF + derivation metadata for recipient
envelope = {
  beef: result[:tx].unpack1('H*'),
  sender_identity_key: ctx[:identity_key],
  outputs: [
    { vout: 0, satoshis: payment,
      derivation_prefix: pay_prefix, derivation_suffix: pay_suffix }
  ]
}

BSV::Wallet::CLI::Output.write_json(envelope)

dtxid = result[:txid].reverse.unpack1('H*')
warn "dtxid:  #{dtxid}"
warn "sent:   #{payment} sats to #{options[:to][0..15]}..."
warn "change: #{change} sats"
warn "fee:    #{fee} sats"
