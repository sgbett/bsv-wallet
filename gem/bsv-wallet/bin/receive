#!/usr/bin/env ruby
# frozen_string_literal: true

# Receive a BRC-100 payment (porcelain).
#
# Reads a JSON envelope from stdin (as produced by bin/send) containing
# BEEF and derivation metadata, then internalizes the payment outputs
# via Engine#internalize_action with proper BRC-42 derivation parameters.
#
# Usage:
#   bin/send alice --to <bob_key> --sats 500 | bin/receive bob
#   bin/receive [wallet] [--basket <name>]

require_relative '../lib/bsv/wallet/cli'
require 'optparse'
require 'json'

wallet_name, args = BSV::Wallet::CLI.extract_wallet_name(ARGV)

options = { basket: 'default' }
OptionParser.new do |opts|
  opts.banner = 'Usage: bin/receive [wallet] [--basket <name>]'
  opts.on('--basket NAME', 'Basket for received outputs (default: default)') { |v| options[:basket] = v }
end.parse!(args)

# Read JSON envelope from stdin
abort 'No data on stdin' if $stdin.tty?
raw = $stdin.read
abort 'Empty stdin' if raw.nil? || raw.empty?

envelope = JSON.parse(raw, symbolize_names: true)
beef_hex = envelope[:beef] || abort('Missing "beef" in envelope')
sender = envelope[:sender_identity_key] || abort('Missing "sender_identity_key" in envelope')
pay_outputs = envelope[:outputs] || abort('Missing "outputs" in envelope')

beef_data = [beef_hex].pack('H*')

ctx = BSV::Wallet::CLI.boot(wallet_name: wallet_name)
engine = ctx[:engine]

# Build internalize output specs from the envelope metadata.
# Use basket insertion protocol with derivation fields so outputs are
# both spendable (via BRC-42 key derivation) and discoverable in a basket.
output_specs = pay_outputs.map do |out|
  {
    output_index: out[:vout],
    protocol: 'basket insertion',
    insertion_remittance: {
      basket: options[:basket],
      derivation_prefix: out[:derivation_prefix],
      derivation_suffix: out[:derivation_suffix],
      sender_identity_key: sender
    }
  }
end

engine.internalize_action(
  tx: beef_data,
  outputs: output_specs,
  description: 'received payment',
  labels: ['cli-receive']
)

pay_outputs.each do |out|
  warn "received: #{out[:satoshis]} sats (vout #{out[:vout]})"
end
