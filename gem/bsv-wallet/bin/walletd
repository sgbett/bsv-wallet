#!/usr/bin/env ruby
# frozen_string_literal: true

# walletd — persistent background process for the BSV wallet.
#
# Runs broadcast retries, proof acquisition, and status polling
# as OMQ-connected fibers inside an Async reactor.
#
# Usage:
#   bin/walletd [wallet_name] [network]
#   bin/walletd alice mainnet

require_relative '../lib/bsv/wallet/cli'

wallet_name, args = BSV::Wallet::CLI.extract_wallet_name(ARGV)

require 'sequel'
require 'logger'
require 'bsv-wallet'

# Load the end-user configure block (~/.bsv-wallet/config.rb) so any
# overrides apply before the first BSV::Wallet.config read below.
BSV::Wallet.load_config_file!

# Network: explicit positional arg wins; otherwise read from config
# (which itself defaults BSV_WALLET_NETWORK → :mainnet).
network = args.first ? args.first.to_sym : BSV::Wallet.config.network

# Walletd runs many Async fibers on one reactor thread (SSE listener,
# broadcast/statuses pull workers, scheduler discovery loops, proof
# acquisition, plus the trap-safe shutdown watcher thread).
#
# fiber_concurrency switches Sequel's pool-checkout key from
# Thread.current to Fiber.current so each fiber gets its own connection
# (without it, all fibers on the reactor thread share one, corrupting
# PG result state -- "undefined method 'nfields' for nil"; see #268).
#
# Enabled here (not in store.rb) so only the daemon process activates
# it; CLI tools keep Sequel's default Thread-based pool, which is fine
# for their single-fiber use.
Sequel.extension :fiber_concurrency

# Pool size: matches the fiber inventory above with headroom. Override
# via the daemon_pool_size config knob (default 16, reads
# BSV_WALLET_DAEMON_SEQUEL_CONNECTIONS). Adjust the Postgres server-side
# max_connections in step (see docker-compose.yml for the relationship).
daemon_pool_size = BSV::Wallet.config.daemon_pool_size

BSV.logger ||= Logger.new($stderr, level: Logger::INFO)

# Resolve wallet credentials. Named wallets (alice/bob/etc.) are
# dev/test fixtures handled by the legacy env_fetch chain until #292.
# End-user (unnamed) mode reads BSV::Wallet.config.
wif = wallet_name ? BSV::Wallet::CLI.env_fetch('WIF', wallet_name) : BSV::Wallet.config.wif
abort BSV::Wallet::CLI.missing_wif_message(wallet_name) if wif.nil? || wif.empty?

db_url = if wallet_name
           BSV::Wallet::CLI.env_fetch_optional('DATABASE_URL', wallet_name)
         else
           BSV::Wallet.config.database_url
         end
db_url ||= BSV::Wallet::CLI.default_sqlite_url(wallet_name)

# Boot store + services (walletd doesn't need Engine or KeyDeriver)
store = BSV::Wallet::Store.connect(db_url, max_connections: daemon_pool_size)
store.migrate!

# GorillaPool (Arcade) is the broadcast porcelain — callbacks via
# X-CallbackToken + SSE status push, the path the wallet is designed
# around. WhatsOnChain's call_broadcast signature isn't kwarg-tolerant
# and its tx_status shape isn't Arcade-compatible, so it must not be in
# the broadcaster's candidate list. WoC stays available for chain queries
# (get_tx, get_merkle_path, etc.) when those wire up here.
provider = BSV::Network::Providers::GorillaPool.default(testnet: network != :mainnet)
broadcaster = BSV::Network::Broadcaster.new(providers: [provider], store: store)

# Deterministic callbackToken: identical to the one CLI.boot derives for
# inline broadcasts, so the listener subscribed here and the engine-side
# submit POSTs use the same routing identifier. See #266.
callback_token = BSV::Wallet::CallbackToken.derive(wif)

BSV.logger.info { "[walletd] Starting for #{wallet_name || 'default'} (#{network})..." }

daemon = BSV::Wallet::Daemon.new(store: store, broadcaster: broadcaster,
                                 wallet: wallet_name, network: network,
                                 callback_token: callback_token)
daemon.run!
