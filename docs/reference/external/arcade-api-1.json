    "/chaintracks/{network}NetBlockHeaders.json": {
      "get": {
        "description": "Returns metadata JSON describing available header files.\nServed from CDN server (default port 3012).\n\nExample response:\n```json\n{\n  \"rootFolder\": \"\",\n  \"jsonFilename\": \"mainNetBlockHeaders.json\",\n  \"headersPerFile\": 100000,\n  \"files\": [\n    {\n      \"chain\": \"main\",\n      \"count\": 100000,\n      \"fileHash\": \"abc123...\",\n      \"fileName\": \"mainNet_0.headers\",\n      \"firstHeight\": 0,\n      \"lastChainWork\": \"0x...\",\n      \"lastHash\": \"000000...\",\n      \"prevChainWork\": \"0x0\",\n      \"prevHash\": \"000000...\",\n      \"sourceUrl\": \"https://...\"\n    }\n  ]\n}\n```\n",
        "parameters": [
          {
            "description": "Network name (main or test)",
            "in": "path",
            "name": "network",
            "required": true,
            "schema": {
              "enum": [
                "main",
                "test"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChaintracksCDNMetadata"
                }
              }
            },
            "description": "CDN metadata",
            "headers": {
              "Cache-Control": {
                "description": "no-cache (metadata should be fetched fresh)",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "Metadata file not found"
          }
        },
        "summary": "CDN metadata file",
        "tags": [
          "chaintracks-CDN"
        ]
      }
    },
    "/chaintracks/{network}Net_{index}.headers": {
      "get": {
        "description": "Returns binary header file containing up to 100,000 block headers.\nEach header is 80 bytes, so a full file is approximately 8MB.\nServed from CDN server (default port 3012).\n\nSupports HTTP Range requests for partial downloads.\n",
        "parameters": [
          {
            "description": "Network name (main or test)",
            "in": "path",
            "name": "network",
            "required": true,
            "schema": {
              "enum": [
                "main",
                "test"
              ],
              "type": "string"
            }
          },
          {
            "description": "File index (0-based). File 0 contains headers 0-99999, file 1 contains 100000-199999, etc.",
            "in": "path",
            "name": "index",
            "required": true,
            "schema": {
              "minimum": 0,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/octet-stream": {
                "schema": {
                  "description": "Concatenated block headers (80 bytes per header, up to 100k headers)",
                  "format": "binary",
                  "type": "string"
                }
              }
            },
            "description": "Binary header data",
            "headers": {
              "Accept-Ranges": {
                "description": "bytes (supports Range requests)",
                "schema": {
                  "type": "string"
                }
              },
              "Cache-Control": {
                "description": "public, max-age=3600 (immutable historical data)",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "206": {
            "content": {
              "application/octet-stream": {
                "schema": {
                  "format": "binary",
                  "type": "string"
                }
              }
            },
            "description": "Partial content (when Range header is used)"
          },
          "404": {
            "description": "Header file not found"
          }
        },
        "summary": "CDN header file",
        "tags": [
          "chaintracks-CDN"
        ]
      }
    },
    "/events": {
