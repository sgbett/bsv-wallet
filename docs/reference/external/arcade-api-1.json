    "/chaintracks/v1/findChainTipHashHex": {
      "get": {
        "description": "Legacy endpoint - Returns the chain tip hash",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChaintracksLegacySuccessResponse"
                }
              }
            },
            "description": "Successful response"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChaintracksErrorResponse"
                }
              }
            },
            "description": "Chain tip not found"
          }
        },
        "summary": "Get chain tip hash (legacy)",
        "tags": [
          "chaintracks-v1"
        ]
      }
    },
