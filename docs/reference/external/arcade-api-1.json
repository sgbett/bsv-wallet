    "/chaintracks/v2/header/hash/{hash}": {
      "get": {
        "description": "Returns a block header for a specific block hash",
        "parameters": [
          {
            "description": "Block hash (hex string)",
            "in": "path",
            "name": "hash",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ChaintracksSuccessResponse"
                    },
                    {
                      "properties": {
                        "value": {
                          "$ref": "#/components/schemas/ChaintracksBlockHeader"
                        }
                      },
                      "type": "object"
                    }
                  ]
                }
              }
            },
            "description": "Successful response",
            "headers": {
              "Cache-Control": {
                "description": "Cache control header (varies based on height)",
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChaintracksErrorResponse"
                }
              }
            },
            "description": "Invalid parameters"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChaintracksErrorResponse"
                }
              }
            },
            "description": "Header not found"
          }
        },
        "summary": "Get header by hash",
        "tags": [
          "chaintracks-v2"
        ]
      }
    },
    "/chaintracks/v2/header/hash/{hash}.bin": {
      "get": {
        "description": "Returns a block header as 80-byte binary data",
        "parameters": [
          {
            "description": "Block hash (hex string)",
            "in": "path",
            "name": "hash",
            "required": true,
            "schema": {
              "type": "string"
