        ],
        "responses": {
          "200": {
            "content": {
              "application/octet-stream": {
                "schema": {
                  "format": "binary",
                  "type": "string"
                }
              }
            },
            "description": "Binary header data",
            "headers": {
              "Cache-Control": {
                "description": "Cache control header (varies based on height)",
                "schema": {
                  "type": "string"
                }
              },
              "X-Block-Height": {
                "description": "Block height",
