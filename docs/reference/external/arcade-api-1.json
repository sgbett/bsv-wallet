{
  "basePath": "/",
  "components": {
    "schemas": {
      "ChaintracksBlockHeader": {
        "properties": {
          "bits": {
            "description": "Difficulty target",
            "format": "uint32",
            "type": "integer"
          },
          "hash": {
            "description": "Block hash",
            "type": "string"
          },
          "height": {
            "description": "Block height in the chain",
            "format": "uint32",
            "type": "integer"
          },
          "merkleRoot": {
            "description": "Merkle root hash",
            "type": "string"
          },
          "nonce": {
            "description": "Nonce",
            "format": "uint32",
            "type": "integer"
          },
          "previousHash": {
            "description": "Previous block hash",
            "type": "string"
          },
          "time": {
            "description": "Block timestamp (Unix time)",
            "format": "uint32",
            "type": "integer"
          },
          "version": {
            "description": "Block version",
            "format": "int32",
            "type": "integer"
          }
        },
        "required": [
          "version",
          "previousHash",
          "merkleRoot",
          "time",
          "bits",
          "nonce",
          "height",
          "hash"
        ],
        "type": "object"
      },
      "ChaintracksCDNFileEntry": {
        "properties": {
          "chain": {
            "description": "Network name (main or test)",
            "example": "main",
            "type": "string"
          },
          "count": {
            "description": "Number of headers in this file",
            "example": 100000,
            "type": "integer"
          },
          "fileHash": {
            "description": "SHA256 hash of the file contents",
            "type": "string"
          },
          "fileName": {
            "description": "Name of the binary header file",
            "example": "mainNet_0.headers",
            "type": "string"
          },
          "firstHeight": {
            "description": "Height of the first header in this file",
            "example": 0,
            "format": "uint32",
            "type": "integer"
          },
          "lastChainWork": {
            "description": "Cumulative chainwork at the last header (hex string)",
            "type": "string"
          },
          "lastHash": {
            "description": "Hash of the last header in this file",
            "type": "string"
          },
          "prevChainWork": {
            "description": "Cumulative chainwork before the first header (hex string)",
            "type": "string"
          },
          "prevHash": {
            "description": "Hash of the block before the first header in this file",
            "type": "string"
          },
          "sourceUrl": {
            "description": "URL where this file can be downloaded",
            "example": "https://chaintracks-cdn-us-1.bsvb.tech/mainNet_0.headers",
            "type": "string"
          }
        },
        "required": [
          "chain",
          "count",
          "fileHash",
          "fileName",
          "firstHeight",
          "lastChainWork",
          "lastHash",
          "prevChainWork",
          "prevHash",
          "sourceUrl"
        ],
        "type": "object"
      },
      "ChaintracksCDNMetadata": {
        "properties": {
          "files": {
            "description": "List of available header files with metadata",
            "items": {
              "$ref": "#/components/schemas/CDNFileEntry"
            },
            "type": "array"
          },
          "headersPerFile": {
            "description": "Number of headers per binary file (typically 100000)",
            "example": 100000,
            "type": "integer"
          },
          "jsonFilename": {
            "description": "Name of this metadata JSON file",
            "example": "mainNetBlockHeaders.json",
            "type": "string"
          },
          "rootFolder": {
            "description": "Root folder path for header files",
            "example": "",
            "type": "string"
          }
        },
        "required": [
          "rootFolder",
          "jsonFilename",
          "headersPerFile",
          "files"
        ],
        "type": "object"
      },
      "ChaintracksErrorResponse": {
        "properties": {
          "code": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "enum": [
              "error"
            ],
            "type": "string"
          }
        },
        "required": [
          "status",
          "code",
          "description"
        ],
        "type": "object"
      },
      "ChaintracksLegacySuccessResponse": {
        "properties": {
          "status": {
            "enum": [
              "success"
            ],
            "type": "string"
          },
          "value": {
            "description": "Response payload (varies by endpoint)"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      },
      "ChaintracksSuccessResponse": {
        "properties": {
          "status": {
            "enum": [
              "success"
            ],
            "type": "string"
          },
          "value": {
            "description": "Response payload (varies by endpoint)"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      }
    }
  },
  "definitions": {
    "arcerrors.ErrorFields": {
      "properties": {
        "detail": {
          "type": "string"
        },
        "extraInfo": {
          "type": "string"
        },
        "status": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "fiber.TransactionRequest": {
      "properties": {
        "rawTx": {
          "example": "0100000001...",
          "type": "string"
        }
      },
      "type": "object"
    },
    "models.Policy": {
      "properties": {
        "maxscriptsizepolicy": {
          "type": "integer"
        },
        "maxtxsigopscountspolicy": {
          "type": "integer"
        },
        "maxtxsizepolicy": {
          "type": "integer"
        },
        "miningFeeBytes": {
          "type": "integer"
        },
        "miningFeeSatoshis": {
          "type": "integer"
        }
      },
      "type": "object"
    },
    "models.Status": {
      "enum": [
        "UNKNOWN",
        "RECEIVED",
        "SENT_TO_NETWORK",
        "ACCEPTED_BY_NETWORK",
        "SEEN_ON_NETWORK",
        "DOUBLE_SPEND_ATTEMPTED",
        "REJECTED",
        "MINED",
        "IMMUTABLE"
      ],
      "type": "string",
      "x-enum-varnames": [
        "StatusUnknown",
        "StatusReceived",
        "StatusSentToNetwork",
        "StatusAcceptedByNetwork",
        "StatusSeenOnNetwork",
        "StatusDoubleSpendAttempted",
        "StatusRejected",
        "StatusMined",
        "StatusImmutable"
      ]
    },
    "models.TransactionStatus": {
      "properties": {
        "blockHash": {
          "type": "string"
        },
        "blockHeight": {
          "type": "integer"
        },
        "competingTxs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "extraInfo": {
          "type": "string"
        },
        "merklePath": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        "status": {
          "type": "integer"
        },
        "timestamp": {
          "type": "string"
        },
        "txStatus": {
          "$ref": "#/definitions/models.Status"
        },
        "txid": {
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "host": "",
  "info": {
    "contact": {
      "name": "BSV Blockchain",
      "url": "https://github.com/bsv-blockchain/arcade"
    },
    "description": "BSV transaction broadcast service with ARC-compatible endpoints.",
    "license": {
