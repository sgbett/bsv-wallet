              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChaintracksErrorResponse"
                }
              }
            },
            "description": "Invalid parameters"
          }
        },
        "summary": "Get multiple headers as binary",
        "tags": [
          "chaintracks-v2"
        ]
      }
    },
