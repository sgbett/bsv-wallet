                  "$ref": "#/components/schemas/ChaintracksErrorResponse"
                }
              }
            },
            "description": "Header not found"
          }
        },
        "summary": "Get header by hash as binary",
        "tags": [
          "chaintracks-v2"
        ]
      }
    },
