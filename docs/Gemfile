# frozen_string_literal: true

# Gemfile for the Jekyll docs site — kept separate from the wallet gem's
# Gemfile (gem/bsv-wallet/) so gem-development dependencies stay clean.
#
# Lockfile policy: docs/Gemfile.lock IS committed. This is a deployable
# application (GitHub Pages), not a library. Pinning the lockfile ensures
# CI produces byte-for-byte identical output to local dev.
#
# Version constraints:
#   - jekyll: ~> 4.3 (minor-version floating; Jekyll 4.x has a stable API)
#   - just-the-docs: exact pin (supply-chain: caps blast radius of stale releases)
#   - jekyll-redirect-from: exact pin (same rationale)

source 'https://rubygems.org'

ruby '>= 3.3'

gem 'jekyll', '~> 4.3'
gem 'just-the-docs', '= 0.12.0'
gem 'jekyll-redirect-from', '= 0.16.0'
# Rewrites relative .md links in markdown to their permalink form at build
# time. MkDocs did this transparently; Jekyll does not — without this plugin,
# every internal [link](path/to/file.md) breaks in the rendered HTML.
gem 'jekyll-relative-links', '0.7.0'

group :development do
  # Jekyll-aware link checker — handles baseurl via swap_urls (lychee can't
  # resolve root-relative URLs like /bsv-wallet/... against a local _site
  # tree, since baseurl is a URL concept not a filesystem path).
  gem 'html-proofer', '~> 5.0'
end
